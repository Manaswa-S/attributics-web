	// should be an array of strings. each item is a paragraph 
	"overview": [
		"Americana Restaurants, the largest restaurant operator in the MENA region and Kazakhstan, manages a large portfolio of brands across multiple markets and customer touchpoints. While the business had access to rich customer and transactional data from CRM platforms, transactional systems, and third-party aggregators, the information remained fragmented across multiple sources and markets, limiting visibility into customer behavior.",
		"Attributics partnered with Americana Restaurants to architect and implement an end-to-end analytics and visualization platform that transformed siloed raw data into a unified, interactive source of truth. The objective was to help marketing, CRM, and leadership teams move beyond high-level sales reporting toward deeper, customer-centric analysis and faster, data-driven decision-making."
	],

	// can be an array of strings of objects. 
		// each object is a point. 
		// each string is a paragraph
	"challenge": [
		{
			"subtitle": "Extreme Data Fragmentation",
			"description": "Each brand operated across multiple markets, and each market had separate CEP instances for behavioral data and separate transactional database instances. This created multiple disconnected silos, making it difficult to establish a unified customer view at the brand, market, and enterprise level."
		},
		{
			"subtitle": "Fragmented Customer Journeys",
			"description": "Behavioral and transactional data existed in separate systems, preventing holistic analysis of the end-to-end customer journey from app install to first transaction and repeat purchase."
		},
		{
			"subtitle": "Complex Business Logic Requirements",
			"description": "The business needed to segment users using contextual definitions that existing tools could not easily support. For example, identifying a customer as “New” depended on the specific brand, market, and channel rather than a single global flag."
		},
		{
			"subtitle": "Lack of Actionable Dashboards",
			"description": "There was limited ability to visualize advanced behavioral patterns such as dormant user reactivation, purchase frequency distribution, and cohort movement over time. This restricted the business’s ability to derive deeper, actionable insights."
		},
		{
			"subtitle": "Manual and Time-Consuming Reporting",
			"description": "Without an automated pipeline, reporting was slow and operationally intensive, making it difficult for teams to respond quickly to changing customer and market behavior."
		}
	],

	// similar to challenge. can be array of string or objects.
	"solution": [
		{
			"subtitle": "",
			"description": "Attributics designed and implemented a scalable analytics and visualization platform on the Microsoft Azure ecosystem, creating a robust pipeline for data ingestion, transformation, storage, and reporting."
		},
		{
			"subtitle": "",
			"description": "At the orchestration layer, Azure Data Factory (ADF) was used to ingest raw data from CEP instances, transactional databases, and other operational sources into Azure Blob Storage. An additional SSIS layer in SSDT (Visual Studio 2022) standardized and combined market-level data before loading it into Blob Storage for downstream processing."
		},
		{
			"subtitle": "",
			"description": "The transformation layer was built on Azure Databricks, where complex ETL jobs were used to cleanse, enrich, and unify the data. During this stage, data was converted into Parquet format to improve storage efficiency and query performance."
		},
		{
			"subtitle": "",
			"description": "The analytics-ready layer was then structured using Delta Tables in Azure Data Lake Storage (ADLS), providing a reliable Gold layer with ACID transactions, schema enforcement, and time-travel capabilities. This served as the single source of truth for reporting and analysis."
		},
		{
			"subtitle": "",
			"description": "For visualization, Power BI was implemented using a hybrid access model. DirectQuery enabled live reporting through Databricks SQL, while Import Mode supported faster dashboard performance for historical and pre-aggregated analysis. Microsoft Entra ID integration ensured secure authentication and controlled access across users."
		},
		{
			"subtitle": "",
			"description": "This architecture enabled business teams to analyze customer behavior across brands, markets, channels, and cohorts in a much more contextual and actionable way."
		}
	],

	// similar to challenge.
	"process": [
		{
			"title": "Data Landscape Assessment",
			"description": "The engagement began with a detailed review of Americana’s existing data ecosystem, including CEP instances, transactional databases, market-level systems, and reporting requirements across brands and regions."
		},
		{
			"title": "Architecture Design",
			"description": "A scalable Azure-based architecture was designed to unify fragmented data sources, support advanced customer analytics, and enable both real-time and historical reporting."
		},
		{
			"title": "Data Ingestion & Transformation Setup",
			"description": "ADF pipelines, SSIS packages, and Databricks transformation workflows were implemented to ingest, clean, standardize, and unify raw data from multiple operational systems."
		},
		{
			"title": "Gold Layer & Dashboard Enablement",
			"description": "Analysis-ready data was structured in Delta Tables within ADLS, and Power BI dashboards were built to support descriptive, cohort-based, and behavioral analysis across multiple business dimensions."
		},
		{
			"title": "Business Use Case Activation",
			"description": "The platform was then used to enable high-value business use cases such as dormant customer reactivation, onboarding funnel optimization, and cross-brand loyalty analysis, allowing teams to connect data directly to decision-making and campaign action."
		}
	],

